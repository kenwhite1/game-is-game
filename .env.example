# ─── Game is Game · environment ─────────────────────────────────────────
# Copy to .env for local dev (or set these in Railway → Variables).
# With NO BOT_TOKEN the server runs in DEV MODE: auth is stubbed to a single
# local user. Perfect for local playtesting of the launcher menu.

# From @BotFather (/newbot). Required in production.
BOT_TOKEN=

# Public HTTPS origin of the deployed launcher (Railway gives you one),
# e.g. https://gameisgame-production.up.railway.app
# Used for the Telegram webhook + the "Открыть" menu button.
APP_URL=

# The launcher bot's @username without the @.
BOT_USERNAME=game_is_game_bot

# Secret path segment for the Telegram webhook (any random string).
WEBHOOK_SECRET=change-me-to-something-random

# Signs session JWTs (any long random string).
JWT_SECRET=change-me-to-a-long-random-string

# SQLite location. On Railway, point this at the mounted volume, e.g. /data
DATA_DIR=./data

# Port (Railway sets this automatically).
PORT=3000

# ─── Linked games (optional overrides) ──────────────────────────────────
# Each tile opens a game's Mini App via t.me/<bot>?startapp. The defaults
# below come from shared/games.ts. Override here only if a bot @username
# differs, or set a *_LINK to point at a fully custom URL.
#
# UNO_BOT=odinkartibot
# CROCO_BOT=krokosha_play_bot
# MAFIA_BOT=secretnochibot
# PET_BOT=sharikrubot
#
# UNO_LINK=https://t.me/odinkartibot?startapp=gg
# CROCO_LINK=https://t.me/krokosha_play_bot?startapp=gg
# MAFIA_LINK=https://t.me/secretnochibot?startapp=gg
# PET_LINK=https://t.me/sharikrubot?startapp=gg
